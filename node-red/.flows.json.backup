    {
        "id": "led_template",
        "type": "ui_template",
        "z": "b1e3b66d34047ed9",
        "group": "group2",
        "name": "LED Indicator",
        "order": 4,
        "width": 4,
        "height": 2,
        "format": "<div style=\"text-align:center; padding:10px;\">\n  <div ng-init=\"status='NORMAL'\" ng-style=\"{\n         'width': '60px',\n         'height': '60px',\n         'border-radius': '50%',\n         'margin': 'auto',\n         'background': msg.payload.status === 'ANOMALY' ? '#ff0000' : '#00cc00',\n         'box-shadow': '0 0 20px ' + (msg.payload.status === 'ANOMALY' ? '#ff0000' : '#00cc00')\n       }\">\n  </div>\n  <p ng-style=\"{'color': msg.payload.status === 'ANOMALY' ? '#ff0000' : '#00cc00'}\"\n    style=\"margin-top:10px; font-weight:bold; font-size:16px;\">\n    {{ msg.payload.status === 'ANOMALY' ? '🔴 ANOMALY DETECTED' : '🟢 NORMAL' }}\n  </p>\n</div>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 620,
        "y": 640,
        "wires": [
            []
        ]
    }
