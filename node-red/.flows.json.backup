    {
        "id": "91ddf0bfdd3abee9",
        "type": "mqtt in",
        "z": "b1e3b66d34047ed9",
        "name": "Temperature Data",
        "topic": "sensors/group11/temperature/data",
        "qos": "2",
        "datatype": "auto",
        "broker": "broker1",
        "inputs": 0,
        "x": 510,
        "y": 180,
        "wires": [
            [
                "fa4822ae9f8a4f51",
                "881d964a612ca7b7"
            ]
        ]
    },
    {
        "id": "fa4822ae9f8a4f51",
        "type": "function",
        "z": "b1e3b66d34047ed9",
        "name": "Parse & Split",
        "func": "var data = msg.payload;\nif(typeof data === 'string') data = JSON.parse(data);\nvar tempMsg = {payload: data.temperature};\nvar humMsg  = {payload: data.humidity};\nvar chartMsg = {payload: data.temperature, topic: \"temperature\"};\nreturn [tempMsg, humMsg, chartMsg];",
        "outputs": 3,
        "x": 760,
        "y": 180,
        "wires": [
            [
                "e625baf9778a241c",
                "a49d5f71fb450bed"
            ],
            [
                "7008fc49a173872f"
            ],
            [
                "bdd99f49f52558b5"
            ]
        ]
    },
