    {
        "id": "switch1",
        "type": "switch",
        "z": "b1e3b66d34047ed9",
        "name": "Anomaly Only",
        "property": "payload.status",
        "propertyType": "msg",
        "rules": [
            {
                "t": "eq",
                "v": "ANOMALY",
                "vt": "str"
