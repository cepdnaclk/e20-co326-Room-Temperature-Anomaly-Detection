#include <Arduino.h>

#define DHTPIN 4

void setup()
{
    Serial.begin(115200);
    delay(3000);
    pinMode(DHTPIN, INPUT_PULLUP);
    Serial.println("=== Pin Diagnostic ===");
}

void loop()
{
    int pinState = digitalRead(DHTPIN);
    Serial.printf("GPIO4 state: %d  (should be 1 when idle)\n", pinState);
    delay(500);
}